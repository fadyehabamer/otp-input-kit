{
  "name": "otp-input-kit",
  "version": "1.1.0",
  "description": "Highly customizable, framework-agnostic OTP input component with RTL, i18n, a11y, timer, and Web Component support",
  "author": "Fady Ehab <a.chwayekh.sparkit@gmail.com>",
  "homepage": "https://github.com/fadyehabamer/otp-input-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fadyehabamer/otp-input-kit.git"
  },
  "bugs": {
    "url": "https://github.com/fadyehabamer/otp-input-kit/issues"
  },
  "main": "dist/otp-input.umd.cjs",
  "module": "dist/otp-input.esm.js",
  "browser": "dist/otp-input.umd.js",
  "unpkg": "dist/otp-input.umd.min.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/otp-input.esm.js",
      "require": "./dist/otp-input.umd.cjs",
      "browser": "./dist/otp-input.umd.js"
    },
    "./react": {
      "types": "./types/react.d.ts",
      "import": "./dist/react.esm.js",
      "require": "./dist/react.cjs"
    },
    "./vue": {
      "types": "./types/vue.d.ts",
      "import": "./dist/vue.esm.js",
      "require": "./dist/vue.cjs"
    },
    "./svelte": {
      "types": "./types/svelte.d.ts",
      "import": "./dist/svelte.esm.js",
      "require": "./dist/svelte.cjs"
    },
    "./angular": {
      "types": "./src/adapters/angular.ts",
      "default": "./src/adapters/angular.ts"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "types",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "dev": "rollup -c rollup.config.js --watch",
    "demo": "npx serve . -p 3000",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "otp",
    "one-time-password",
    "input",
    "rtl",
    "i18n",
    "accessibility",
    "a11y",
    "vanilla-js",
    "web-component",
    "timer",
    "arabic",
    "persian",
    "hebrew",
    "zero-dependency"
  ],
  "type": "module",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17",
    "vue": ">=3",
    "@angular/core": ">=16"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/pluginutils": "^5.1.0",
    "rollup": "^4.9.0"
  }
}
